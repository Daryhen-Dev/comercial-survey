# ─── Supabase ────────────────────────────────────────────────────────────────
# Pooled URL (pgBouncer transaction mode, port 6543) — used for runtime queries
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session mode (port 5432 on pooler host) — used for prisma db push / migrations
# NOTE: use pooler host (not db.[ref].supabase.co) — direct host requires IPv6
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
# On Vercel this is set automatically — only needed locally
NEXTAUTH_URL="http://localhost:3000"

# ─── Upstash Redis (rate limiting) ────────────────────────────────────────────
# Get these from Upstash dashboard → your Redis database → REST API
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Local development only (Docker) ──────────────────────────────────────────
POSTGRES_USER=survey_user
POSTGRES_PASSWORD=survey_pass
POSTGRES_DB=comercial_survey
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
